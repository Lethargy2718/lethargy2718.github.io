{% extends "base.njk" %}
{% block content %}
<article class="post">
	<header class="post-header">
		<h1>{{ title }}</h1>
		{% if description %}<p class="post-description">{{ description }}</p>{% endif %}
		{% if date %}<time datetime="{{ date | htmlDateString }}">{{ date | formatDate }}</time>{% endif %}
	</header>
	<div class="post-content">{{ content | safe }}</div>
	{% set siblings = collections.all | eleventyNavigation(eleventyNavigation.parent) %}
	{% set isSeries = collections.all | isSeriesParent(eleventyNavigation.parent) %}
	{% if isSeries and siblings.length > 1 %}
	{% set currentIndex = siblings | findNavIndex(eleventyNavigation.key) %}
	<nav class="post-nav" aria-label="Post navigation">
		<div class="post-nav-links">
			{% if currentIndex > 0 %}
			<a href="{{ siblings[currentIndex - 1].url }}" class="post-nav-prev">
				<span class="post-nav-label">&larr; Previous</span>
				<span class="post-nav-title">{{ siblings[currentIndex - 1].title }}</span>
			</a>
			{% else %}<span class="post-nav-prev empty"></span>{% endif %}
			{% if currentIndex < siblings.length - 1 %} <a href="{{ siblings[currentIndex + 1].url }}"
				class="post-nav-next">
				<span class="post-nav-label">Next &rarr;</span>
				<span class="post-nav-title">{{ siblings[currentIndex + 1].title }}</span>
				</a>
				{% else %}<span class="post-nav-next empty"></span>{% endif %}
		</div>
	</nav>
	{% endif %}
</article>
{% endblock %}